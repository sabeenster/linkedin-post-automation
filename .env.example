# LinkedIn Post Automation — Environment Variables
# Copy to .env and fill in your values

# Claude API (required)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Email notifications (optional — uses Resend)
RESEND_API_KEY=re_your_key_here
RESEND_FROM_EMAIL=LinkedIn Drafts <drafts@updates.agentway.com>
RESEND_TO_EMAIL=sabeen@agentway.com
